#!/usr/bin/env bash
#SBATCH --job-name=axis-kits-gpu
#SBATCH --partition=gpu
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=12
#SBATCH --mem=90000
# GPU request — adjust to your site (examples):
#SBATCH --gres=gpu:1
# Wall time intentionally omitted; add #SBATCH --time=... if your site requires it.
#
# KiTS dry run on GPU: same flow as dev/run_local_kits.sh with AXIS_DEVICE=cuda.
# --mem is in megabytes on typical Slurm sites (90000 ≈ 88 GiB).
#
# Submit (example) — run from INSIDE the repo so SLURM_SUBMIT_DIR is the clone.
# (Slurm copies this script to a spool path; do not rely on the script file location.)
#   cd /path/to/axis-inference-pipeline && sbatch dev/slurm_gpu_kits.job
# Or: sbatch --chdir=/path/to/axis-inference-pipeline dev/slurm_gpu_kits.job  (Slurm 20.11+)
# Or: sbatch --export=ALL,AXIS_REPO_ROOT=/path/to/axis-inference-pipeline dev/slurm_gpu_kits.job
#
# Process one case, or all KiTS-* folders under AXIS_KITS_ROOT (default: ALL):
#   sbatch --export=ALL,CASE_NAME=KiTS-00042 dev/slurm_gpu_kits.job
#   sbatch dev/slurm_gpu_kits.job   # CASE_NAME defaults to ALL
#
# Optional overrides (export before sbatch or pass via --export):
#   AXIS_REPO_ROOT   — absolute path to repo root if this .job file is not under dev/ in the clone
#   AXIS_VENV_DIR    — path to venv if not <repo>/.venv (must contain bin/axis-pn)
#   AXIS_PYTHON      — interpreter for ./dev/setup_local_models.sh (default python3.10)
#   AXIS_KITS_ROOT   — parent of KiTS-XXXXX folders (default below)
#   AXIS_WEIGHTS_DIR — PNvsRN checkpoint tree (default: <repo>/pnvrn_folds)
#   AXIS_WORK_ROOT   — output root (default: <repo>/local-runs)
#   AXIS_DICOM_BACKEND — auto (default), sitk, or dcm2niix; auto uses SimpleITK when dcm2niix is missing
#   AXIS_DCM2NIIX    — full path to dcm2niix if you use --dicom-backend dcm2niix without it on PATH
#   AXIS_TOTALSEG_DEVICE — TotalSegmentator --device: use "cpu" if PyTorch warns the NVIDIA driver is too old
#                          (SWP --device cuda can still fail until PyTorch matches the host driver).
#
# If your cluster uses a different GPU syntax, replace or edit the #SBATCH --gres line
# (e.g. --gpus-per-node=1, or partition-specific flags).
#
set -euo pipefail

CASE_NAME="${CASE_NAME:-ALL}"

# Slurm executes a *copy* of this script under a spool dir (e.g. .../slurm/var/spool/...), so
# $BASH_SOURCE/../.. is NOT the git repo. Prefer SLURM_SUBMIT_DIR (cwd when sbatch ran) or AXIS_REPO_ROOT.
if [[ -n "${AXIS_REPO_ROOT:-}" ]]; then
  REPO_ROOT="$(cd "${AXIS_REPO_ROOT}" && pwd)" || {
    echo "AXIS_REPO_ROOT is not a directory: ${AXIS_REPO_ROOT}" >&2
    exit 1
  }
elif [[ -n "${SLURM_SUBMIT_DIR:-}" && -f "${SLURM_SUBMIT_DIR}/dev/run_local_kits.sh" ]]; then
  REPO_ROOT="$(cd "${SLURM_SUBMIT_DIR}" && pwd)"
else
  _FROM_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  if [[ -f "${_FROM_SCRIPT}/dev/run_local_kits.sh" ]]; then
    REPO_ROOT="${_FROM_SCRIPT}"
  else
    echo "Could not find axis-inference-pipeline repo root." >&2
    echo "Slurm runs this script from a spool directory; \$BASH_SOURCE points at ${BASH_SOURCE[0]}" >&2
    echo "Fix: submit from the clone so SLURM_SUBMIT_DIR is set correctly:" >&2
    echo "  cd /path/to/axis-inference-pipeline && sbatch dev/slurm_gpu_kits.job" >&2
    echo "Or pass the repo explicitly:" >&2
    echo "  sbatch --export=ALL,AXIS_REPO_ROOT=/path/to/axis-inference-pipeline dev/slurm_gpu_kits.job" >&2
    exit 1
  fi
fi
cd "${REPO_ROOT}" || exit 1

VENV_DIR="${AXIS_VENV_DIR:-${REPO_ROOT}/.venv}"
AXIS_PN="${VENV_DIR}/bin/axis-pn"

CPUS="${SLURM_CPUS_PER_TASK:-12}"
export OMP_NUM_THREADS="${CPUS}"
export MKL_NUM_THREADS="${CPUS}"
export OPENBLAS_NUM_THREADS="${CPUS}"
export NUMEXPR_NUM_THREADS="${CPUS}"

# AIM-HI Lab layout: .../kits-dicoms/KiTS-XXXXX (each case is a direct child of AXIS_KITS_ROOT)
export AXIS_KITS_ROOT="${AXIS_KITS_ROOT:-/home/jonnalr/AIM-HI-Lab/kits-dicoms}"
export AXIS_DEVICE="${AXIS_DEVICE:-cuda}"

if [[ ! -x "${AXIS_PN}" ]]; then
  echo "Cannot run axis-pn at: ${AXIS_PN}" >&2
  echo "  REPO_ROOT=${REPO_ROOT}" >&2
  echo "  VENV_DIR=${VENV_DIR}" >&2
  echo "Fix one of:" >&2
  echo "  1) On a login/build node, create the venv in this clone:" >&2
  echo "       cd ${REPO_ROOT} && ./dev/setup_local_models.sh" >&2
  echo "  2) If your venv lives elsewhere: export AXIS_VENV_DIR=/path/to/venv before sbatch" >&2
  echo "  3) If REPO_ROOT looks like a Slurm spool path, submit from the clone:" >&2
  echo "       cd /path/to/axis-inference-pipeline && sbatch dev/slurm_gpu_kits.job" >&2
  echo "     or: sbatch --export=ALL,AXIS_REPO_ROOT=/path/to/axis-inference-pipeline dev/slurm_gpu_kits.job" >&2
  echo "For GPU, ensure PyTorch in that venv is CUDA-enabled (see README cluster GPU note)." >&2
  exit 1
fi

export AXIS_VENV_DIR="${VENV_DIR}"
exec bash "${REPO_ROOT}/dev/run_local_kits.sh" "${CASE_NAME}"
