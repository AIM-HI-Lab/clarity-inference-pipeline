# Copy to dev/260701_init/slurm_s3_worker.env and edit.
# Loaded automatically by slurm_s3_worker.job when present.

# S3 / AWS
# CLARITY_S3_BUCKET=clarity-upload-portal-prod
AWS_PROFILE=clarity-worker
AWS_DEFAULT_REGION=us-east-2
# AWS_SHARED_CREDENTIALS_FILE=${HOME}/.aws/credentials

# Shared nnU-Net v2 (same paths as clarity_local_env_overrides.sh)
CLARITY_NNUNET_V2_RESULTS=${HOME}/AIM-HI-Lab/models/radiomics_pipeline_models/nnUNet_v2/nnUNet_results_v2
CLARITY_NNUNET_V2_RAW=${HOME}/AIM-HI-Lab/models/radiomics_pipeline_models/nnUNet_v2/nnUNet_raw_data_v2
CLARITY_NNUNET_V2_PREPROCESSED=${HOME}/AIM-HI-Lab/models/radiomics_pipeline_models/nnUNet_v2/nnUNet_preprocessed_v2

# Worker behavior
CLARITY_S3_PREFIX_ROOT=clarity/submissions
CLARITY_WORK_ROOT=${HOME}/beegfs/temp/clarity-s3-worker
CLARITY_DEVICE=cuda
CLARITY_DICOM_BACKEND=sitk
CLARITY_S3_POLL_SECONDS=30
CLARITY_S3_MAX_CASES=
CLARITY_DELETE_INPUT_AFTER_SUCCESS=0
CLARITY_DELETE_INPUT_AFTER_FAILURE=0
CLARITY_S3_ONCE=0
