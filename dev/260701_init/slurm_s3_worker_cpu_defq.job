#!/usr/bin/env bash
#SBATCH --job-name=clarity-s3-cpu
#SBATCH -p defq
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=48
#SBATCH --mem=180000
#
# CPU S3 worker on defq (48 cores / ~180 GB RAM per node).
# Does not request GPUs, nodes (-N), or wall time.
#
# Submit from the repo clone:
#   cd ~/AIM-HI-Lab/code/$USER/clarity-inference-pipeline
#   sbatch dev/260701_init/slurm_s3_worker_cpu_defq.job
#
# Process one pending submission and exit (default):
#   sbatch dev/260701_init/slurm_s3_worker_cpu_defq.job
#
# Override via --export=ALL,KEY=value or dev/260701_init/slurm_s3_worker.env
#
set -euo pipefail

export CLARITY_DEVICE="${CLARITY_DEVICE:-cpu}"
export CLARITY_S3_WORKER_COUNT="${CLARITY_S3_WORKER_COUNT:-1}"
export CLARITY_DEBUG_CUDA=0
export CLARITY_S3_ONCE="${CLARITY_S3_ONCE:-1}"

# Speed defaults for CPU (override or unset via --export if you want full quality).
export CLARITY_TUMOR_EXTRA="${CLARITY_TUMOR_EXTRA:---disable_tta}"
export CLARITY_TOTALSEG_EXTRA="${CLARITY_TOTALSEG_EXTRA:---fast}"
export SWP_DATA_NUM_WORKERS="${SWP_DATA_NUM_WORKERS:-8}"

DEV_INIT_REL="dev/260701_init"

_resolve_repo_root() {
  if [[ -n "${CLARITY_REPO_ROOT:-}" ]]; then
    cd "${CLARITY_REPO_ROOT}" && pwd
    return
  fi
  if [[ -n "${SLURM_SUBMIT_DIR:-}" && -f "${SLURM_SUBMIT_DIR}/${DEV_INIT_REL}/setup.sh" ]]; then
    cd "${SLURM_SUBMIT_DIR}" && pwd
    return
  fi
  local from_script
  from_script="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
  if [[ -f "${from_script}/${DEV_INIT_REL}/setup.sh" ]]; then
    echo "${from_script}"
    return
  fi
  return 1
}

if ! REPO_ROOT="$(_resolve_repo_root)"; then
  echo "Could not find clarity-inference-pipeline repo root." >&2
  echo "Submit from the clone:" >&2
  echo "  cd ~/AIM-HI-Lab/code/\$USER/clarity-inference-pipeline && sbatch dev/260701_init/slurm_s3_worker_cpu_defq.job" >&2
  echo "Or: sbatch --export=ALL,CLARITY_REPO_ROOT=/path/to/clone dev/260701_init/slurm_s3_worker_cpu_defq.job" >&2
  exit 1
fi

WORKER_JOB="${REPO_ROOT}/${DEV_INIT_REL}/slurm_s3_worker.job"
if [[ ! -f "${WORKER_JOB}" ]]; then
  echo "Missing worker script: ${WORKER_JOB}" >&2
  exit 1
fi

exec bash "${WORKER_JOB}"
