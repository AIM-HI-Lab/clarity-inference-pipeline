#!/usr/bin/env bash
#SBATCH --job-name=axis-kits-cpu
#SBATCH --partition=xtreme
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=96
#SBATCH --mem=2T
# Wall time intentionally omitted; add #SBATCH --time=... if your site requires it.
#
# KiTS dry run on CPU (same flow as dev/run_local_kits.sh / Docker CPU predict).
#
# Submit (example) — run from INSIDE the repo (Slurm copies this script to spool; see slurm_gpu_kits.job).
#   cd /path/to/axis-inference-pipeline && sbatch dev/slurm_xtreme_kits_cpu.job
# Or: sbatch --export=ALL,AXIS_REPO_ROOT=/path/to/axis-inference-pipeline dev/slurm_xtreme_kits_cpu.job
#
# Data + case:
#   sbatch --export=ALL,AXIS_KITS_ROOT=/path/to/c4kc_kits,CASE_NAME=KiTS-00042 dev/slurm_xtreme_kits_cpu.job
#
# Required (export on sbatch):
#   AXIS_KITS_ROOT   — parent of KiTS-XXXXX folders
# Optional overrides:
#   AXIS_REPO_ROOT   — absolute path to repo root if this .job file is not under dev/ in the clone
#   AXIS_VENV_DIR    — path to venv if not <repo>/.venv (must contain bin/axis-pn)
#   AXIS_PYTHON      — interpreter for ./dev/setup_local_models.sh (default python3.10)
#   CASE_NAME        — default KiTS-00000; must exist under AXIS_KITS_ROOT
#   AXIS_WEIGHTS_DIR — PNvsRN checkpoint tree (default: <repo>/pnvrn_folds)
#   AXIS_WORK_ROOT   — output root (default: <repo>/local-runs)
#   AXIS_DEVICE      — default cpu (do not change for this job)
#
set -euo pipefail

CASE_NAME="${CASE_NAME:-KiTS-00000}"

# Slurm runs a spool *copy* of this script; $BASH_SOURCE/../.. is not the repo. Prefer SLURM_SUBMIT_DIR.
if [[ -n "${AXIS_REPO_ROOT:-}" ]]; then
  REPO_ROOT="$(cd "${AXIS_REPO_ROOT}" && pwd)" || {
    echo "AXIS_REPO_ROOT is not a directory: ${AXIS_REPO_ROOT}" >&2
    exit 1
  }
elif [[ -n "${SLURM_SUBMIT_DIR:-}" && -f "${SLURM_SUBMIT_DIR}/dev/run_local_kits.sh" ]]; then
  REPO_ROOT="$(cd "${SLURM_SUBMIT_DIR}" && pwd)"
else
  _FROM_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  if [[ -f "${_FROM_SCRIPT}/dev/run_local_kits.sh" ]]; then
    REPO_ROOT="${_FROM_SCRIPT}"
  else
    echo "Could not find axis-inference-pipeline repo root." >&2
    echo "Slurm runs this script from a spool directory; \$BASH_SOURCE points at ${BASH_SOURCE[0]}" >&2
    echo "Fix: cd /path/to/axis-inference-pipeline && sbatch dev/slurm_xtreme_kits_cpu.job" >&2
    echo "Or: sbatch --export=ALL,AXIS_REPO_ROOT=/path/to/axis-inference-pipeline dev/slurm_xtreme_kits_cpu.job" >&2
    exit 1
  fi
fi
cd "${REPO_ROOT}" || exit 1

VENV_DIR="${AXIS_VENV_DIR:-${REPO_ROOT}/.venv}"
AXIS_PN="${VENV_DIR}/bin/axis-pn"

export OMP_NUM_THREADS="${SLURM_CPUS_PER_TASK:-96}"
export MKL_NUM_THREADS="${SLURM_CPUS_PER_TASK:-96}"
export OPENBLAS_NUM_THREADS="${SLURM_CPUS_PER_TASK:-96}"
export NUMEXPR_NUM_THREADS="${SLURM_CPUS_PER_TASK:-96}"

if [[ -z "${AXIS_KITS_ROOT:-}" ]]; then
  echo "AXIS_KITS_ROOT is required (parent of KiTS-XXXXX directories)." >&2
  echo "Example: sbatch --export=ALL,AXIS_KITS_ROOT=/path/to/c4kc_kits,CASE_NAME=KiTS-00023 dev/slurm_xtreme_kits_cpu.job" >&2
  exit 1
fi
if [[ ! -d "${AXIS_KITS_ROOT}" ]]; then
  echo "AXIS_KITS_ROOT is not a directory: ${AXIS_KITS_ROOT}" >&2
  exit 1
fi
export AXIS_KITS_ROOT

export AXIS_DEVICE="${AXIS_DEVICE:-cpu}"

if [[ ! -x "${AXIS_PN}" ]]; then
  echo "Cannot run axis-pn at: ${AXIS_PN}" >&2
  echo "  REPO_ROOT=${REPO_ROOT}" >&2
  echo "  VENV_DIR=${VENV_DIR}" >&2
  echo "Fix one of:" >&2
  echo "  1) On a login/build node, create the venv in this clone:" >&2
  echo "       cd ${REPO_ROOT} && ./dev/setup_local_models.sh" >&2
  echo "  2) If your venv lives elsewhere: export AXIS_VENV_DIR=/path/to/venv before sbatch" >&2
  echo "  3) If REPO_ROOT looks like a Slurm spool path, submit from the clone:" >&2
  echo "       cd /path/to/axis-inference-pipeline && sbatch dev/slurm_xtreme_kits_cpu.job" >&2
  echo "     or: sbatch --export=ALL,AXIS_REPO_ROOT=/path/to/axis-inference-pipeline dev/slurm_xtreme_kits_cpu.job" >&2
  exit 1
fi

export AXIS_VENV_DIR="${VENV_DIR}"
exec bash "${REPO_ROOT}/dev/run_local_kits.sh" "${CASE_NAME}"
