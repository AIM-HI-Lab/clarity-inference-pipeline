#!/usr/bin/env bash
#SBATCH --job-name=clarity-s3-worker
#SBATCH --partition=gpu
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=12
#SBATCH --mem=32200
#SBATCH --gres=gpu:1
#SBATCH --output=slurm-%x-%j.out
# Wall time intentionally omitted; add #SBATCH --time=... if your site requires it.
#
# Run CLARITY S3 worker on a private node via Slurm.
#
# Submit examples:
#   cd /path/to/clarity-inference-pipeline && sbatch dev/slurm_s3_worker.job
#   sbatch --export=ALL,CLARITY_REPO_ROOT=/path/to/clarity-inference-pipeline dev/slurm_s3_worker.job
#
# One-shot mode from sbatch:
#   sbatch --export=ALL,CLARITY_S3_ONCE=1 dev/slurm_s3_worker.job
#
# Zero-config defaults (aligned to this repo/chat):
#   CLARITY_S3_BUCKET defaults to clarity-upload-portal-prod
#   CLARITY_WEIGHTS_DIR defaults to <repo>/pnvrn_folds
#
# Optional env vars:
#   CLARITY_S3_PREFIX_ROOT=clarity/submissions
#   CLARITY_WORK_ROOT=/scratch/$USER/clarity-s3-worker
#   CLARITY_DEVICE=cuda|cpu
#   CLARITY_S3_POLL_SECONDS=30
#   CLARITY_S3_MAX_CASES=4
#   CLARITY_DELETE_INPUT_AFTER_SUCCESS=1
#   CLARITY_DELETE_INPUT_AFTER_FAILURE=0
#   CLARITY_S3_ONCE=0|1
#   AWS_DEFAULT_REGION=us-east-1
#   AWS_PROFILE=clarity-worker             # if using ~/.aws/credentials
#   AWS_SHARED_CREDENTIALS_FILE=/secure/path/credentials
#
set -euo pipefail

# -----------------------------------------------------------------------------
# Quick config (easy mode)
# -----------------------------------------------------------------------------
# Option A (recommended): create dev/slurm_s3_worker.env with KEY=VALUE lines.
# Option B: edit defaults below.
# Option C: override at submit time via: sbatch --export=ALL,KEY=value ...
#
# Example env file:
#   CLARITY_S3_BUCKET=clarity-upload-portal-prod
#   CLARITY_WEIGHTS_DIR=/absolute/path/to/pnvrn_folds
#   AWS_PROFILE=clarity-worker
#   AWS_DEFAULT_REGION=us-east-1
#
CLARITY_S3_ENV_FILE_DEFAULT="dev/slurm_s3_worker.env"
CLARITY_S3_BUCKET_DEFAULT="clarity-upload-portal-prod"
CLARITY_WEIGHTS_DIR_DEFAULT=""  # if blank, uses <repo>/pnvrn_folds
CLARITY_S3_PREFIX_ROOT_DEFAULT="clarity/submissions"
CLARITY_WORK_ROOT_DEFAULT="/home/jonnalr/AIM-HI-Lab/temp"  # if blank, uses <repo>/local-s3-worker
CLARITY_DEVICE_DEFAULT="cuda"
CLARITY_DICOM_BACKEND_DEFAULT="sitk"
CLARITY_DCM2NIIX_DEFAULT="dcm2niix"
CLARITY_S3_POLL_SECONDS_DEFAULT="30"
CLARITY_S3_MAX_CASES_DEFAULT=""  # blank means no limit
CLARITY_DELETE_INPUT_AFTER_SUCCESS_DEFAULT="0"
CLARITY_DELETE_INPUT_AFTER_FAILURE_DEFAULT="0"
CLARITY_S3_ONCE_DEFAULT="1"
CLARITY_FAIL_ON_EMPTY_TUMOR_DEFAULT="0"
AWS_DEFAULT_REGION_DEFAULT="us-east-2"
AWS_PROFILE_DEFAULT="clarity-worker"  # optional (for ~/.aws/credentials profile)
AWS_SHARED_CREDENTIALS_FILE_DEFAULT="/home/jonnalr/.aws/credentials"
AWS_CONFIG_FILE_DEFAULT="/home/jonnalr/.aws/config"

# Slurm executes a copy under a spool dir, so prefer submit dir or explicit CLARITY_REPO_ROOT.
if [[ -n "${CLARITY_REPO_ROOT:-}" ]]; then
  REPO_ROOT="$(cd "${CLARITY_REPO_ROOT}" && pwd)" || {
    echo "CLARITY_REPO_ROOT is not a directory: ${CLARITY_REPO_ROOT}" >&2
    exit 1
  }
elif [[ -n "${SLURM_SUBMIT_DIR:-}" && -f "${SLURM_SUBMIT_DIR}/dev/run_local_dicom_batch.sh" ]]; then
  REPO_ROOT="$(cd "${SLURM_SUBMIT_DIR}" && pwd)"
else
  _FROM_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  if [[ -f "${_FROM_SCRIPT}/dev/run_local_dicom_batch.sh" ]]; then
    REPO_ROOT="${_FROM_SCRIPT}"
  else
    echo "Could not find clarity-inference-pipeline repo root." >&2
    echo "Slurm runs this script from a spool directory; \$BASH_SOURCE points at ${BASH_SOURCE[0]}" >&2
    echo "Fix: submit from the clone so SLURM_SUBMIT_DIR is set correctly:" >&2
    echo "  cd /path/to/clarity-inference-pipeline && sbatch dev/slurm_s3_worker.job" >&2
    echo "Or pass the repo explicitly:" >&2
    echo "  sbatch --export=ALL,CLARITY_REPO_ROOT=/path/to/clarity-inference-pipeline dev/slurm_s3_worker.job" >&2
    exit 1
  fi
fi
cd "${REPO_ROOT}"

VENV_DIR="${CLARITY_VENV_DIR:-${REPO_ROOT}/.venv}"
WORKER_BIN="${VENV_DIR}/bin/clarity-s3-worker"

CPUS="${SLURM_CPUS_PER_TASK:-12}"
export OMP_NUM_THREADS="${CPUS}"
export MKL_NUM_THREADS="${CPUS}"
export OPENBLAS_NUM_THREADS="${CPUS}"
export NUMEXPR_NUM_THREADS="${CPUS}"

# Load auto-generated local env (sets CLARITY_NNUNET_V2_* to repo-local defaults).
if [[ -f "${REPO_ROOT}/dev/clarity_local_env.sh" ]]; then
  # shellcheck disable=SC1091
  source "${REPO_ROOT}/dev/clarity_local_env.sh"
fi

# Load config file AFTER clarity_local_env.sh so user overrides (e.g. shared model paths) win.
CLARITY_S3_ENV_FILE="${CLARITY_S3_ENV_FILE:-${REPO_ROOT}/${CLARITY_S3_ENV_FILE_DEFAULT}}"
if [[ -f "${CLARITY_S3_ENV_FILE}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${CLARITY_S3_ENV_FILE}"
  set +a
  echo "Loaded config from ${CLARITY_S3_ENV_FILE}"
fi
export PATH="${VENV_DIR}/bin:${PATH}"

# Mirror dev/run_local_dicom_batch.sh nnU-Net v2 env wiring so Dataset123_Kits23 resolves.
if [[ -n "${CLARITY_NNUNET_V1_RAW:-}" ]]; then
  export nnUNet_raw_data_base="${CLARITY_NNUNET_V1_RAW}"
fi
if [[ -n "${CLARITY_NNUNET_V1_PREPROCESSED:-}" ]]; then
  export nnUNet_preprocessed="${CLARITY_NNUNET_V1_PREPROCESSED}"
fi
if [[ -n "${CLARITY_NNUNET_V1_RESULTS:-}" ]]; then
  export RESULTS_FOLDER="${CLARITY_NNUNET_V1_RESULTS}"
fi
if [[ -n "${CLARITY_NNUNET_V2_RAW:-}" ]]; then
  export nnUNet_raw="${CLARITY_NNUNET_V2_RAW}"
fi
if [[ -n "${CLARITY_NNUNET_V2_PREPROCESSED:-}" ]]; then
  export nnUNet_preprocessed="${CLARITY_NNUNET_V2_PREPROCESSED}"
fi
if [[ -n "${CLARITY_NNUNET_V2_RESULTS:-}" ]]; then
  export nnUNet_results="${CLARITY_NNUNET_V2_RESULTS}"
fi

# nnU-Net uses TMPDIR heavily; on Slurm prefer node-local temp if provided.
if [[ -n "${SLURM_TMPDIR:-}" ]]; then
  export TMPDIR="${TMPDIR:-${SLURM_TMPDIR}}"
fi

if [[ ! -x "${WORKER_BIN}" ]]; then
  echo "Cannot run worker at ${WORKER_BIN}" >&2
  echo "Create env with: ./dev/setup_local_models.sh" >&2
  echo "Or set CLARITY_VENV_DIR to an existing venv path." >&2
  exit 1
fi
export CLARITY_VENV_DIR="${VENV_DIR}"

export CLARITY_S3_BUCKET="${CLARITY_S3_BUCKET:-${CLARITY_S3_BUCKET_DEFAULT}}"
export CLARITY_WEIGHTS_DIR="${CLARITY_WEIGHTS_DIR:-${CLARITY_WEIGHTS_DIR_DEFAULT}}"
if [[ -z "${CLARITY_WEIGHTS_DIR}" ]]; then
  export CLARITY_WEIGHTS_DIR="${REPO_ROOT}/pnvrn_folds"
fi
export AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-${AWS_DEFAULT_REGION_DEFAULT}}"
AWS_PROFILE_VALUE="${AWS_PROFILE:-${AWS_PROFILE_DEFAULT}}"
if [[ -n "${AWS_PROFILE_VALUE}" ]]; then
  export AWS_PROFILE="${AWS_PROFILE_VALUE}"
else
  unset AWS_PROFILE || true
fi
export AWS_SHARED_CREDENTIALS_FILE="${AWS_SHARED_CREDENTIALS_FILE:-${AWS_SHARED_CREDENTIALS_FILE_DEFAULT}}"
export AWS_CONFIG_FILE="${AWS_CONFIG_FILE:-${AWS_CONFIG_FILE_DEFAULT}}"
export CLARITY_S3_PREFIX_ROOT="${CLARITY_S3_PREFIX_ROOT:-${CLARITY_S3_PREFIX_ROOT_DEFAULT}}"
export CLARITY_WORK_ROOT="${CLARITY_WORK_ROOT:-${CLARITY_WORK_ROOT_DEFAULT}}"
if [[ -z "${CLARITY_WORK_ROOT}" ]]; then
  export CLARITY_WORK_ROOT="${REPO_ROOT}/local-s3-worker"
fi
export CLARITY_DEVICE="${CLARITY_DEVICE:-${CLARITY_DEVICE_DEFAULT}}"
export CLARITY_DICOM_BACKEND="${CLARITY_DICOM_BACKEND:-${CLARITY_DICOM_BACKEND_DEFAULT}}"
export CLARITY_DCM2NIIX="${CLARITY_DCM2NIIX:-${CLARITY_DCM2NIIX_DEFAULT}}"
export CLARITY_S3_POLL_SECONDS="${CLARITY_S3_POLL_SECONDS:-${CLARITY_S3_POLL_SECONDS_DEFAULT}}"
export CLARITY_S3_MAX_CASES="${CLARITY_S3_MAX_CASES:-${CLARITY_S3_MAX_CASES_DEFAULT}}"
export CLARITY_DELETE_INPUT_AFTER_FAILURE="${CLARITY_DELETE_INPUT_AFTER_FAILURE:-${CLARITY_DELETE_INPUT_AFTER_FAILURE_DEFAULT}}"
export CLARITY_DELETE_INPUT_AFTER_SUCCESS="${CLARITY_DELETE_INPUT_AFTER_SUCCESS:-${CLARITY_DELETE_INPUT_AFTER_SUCCESS_DEFAULT}}"
export CLARITY_S3_ONCE="${CLARITY_S3_ONCE:-${CLARITY_S3_ONCE_DEFAULT}}"
export CLARITY_FAIL_ON_EMPTY_TUMOR="${CLARITY_FAIL_ON_EMPTY_TUMOR:-${CLARITY_FAIL_ON_EMPTY_TUMOR_DEFAULT}}"

if [[ -z "${CLARITY_S3_BUCKET}" ]]; then
  echo "CLARITY_S3_BUCKET is empty (unexpected)." >&2
  echo "Set via ${REPO_ROOT}/${CLARITY_S3_ENV_FILE_DEFAULT} or --export." >&2
  exit 1
fi
if [[ ! -d "${CLARITY_WEIGHTS_DIR}" ]]; then
  echo "CLARITY_WEIGHTS_DIR does not exist: ${CLARITY_WEIGHTS_DIR}" >&2
  echo "Expected default is <repo>/pnvrn_folds. If yours is elsewhere, set CLARITY_WEIGHTS_DIR." >&2
  exit 1
fi
if [[ -z "${nnUNet_results:-}" || -z "${nnUNet_preprocessed:-}" || -z "${nnUNet_raw:-}" ]]; then
  echo "nnU-Net v2 setup is not initialized for this job environment." >&2
  echo "Expected nnUNet v2 vars are missing (nnUNet_results / nnUNet_preprocessed / nnUNet_raw)." >&2
  echo "Run once from repo root: ./dev/setup_local_models.sh" >&2
  echo "Or ensure dev/clarity_local_env.sh is present and readable on compute node." >&2
  exit 1
fi

mkdir -p "${CLARITY_WORK_ROOT}"

# GPU diagnostics (disable with CLARITY_DEBUG_CUDA=0).
if [[ "${CLARITY_DEVICE}" == "cuda" && "${CLARITY_DEBUG_CUDA:-1}" != "0" ]]; then
  bash "${REPO_ROOT}/dev/check_gpu_env.sh" || true
fi

echo "Worker config:"
echo "  bucket=${CLARITY_S3_BUCKET}"
echo "  region=${AWS_DEFAULT_REGION}"
echo "  prefix=${CLARITY_S3_PREFIX_ROOT}"
echo "  work_root=${CLARITY_WORK_ROOT}"
echo "  weights_dir=${CLARITY_WEIGHTS_DIR}"
echo "  device=${CLARITY_DEVICE}"
echo "  dicom_backend=${CLARITY_DICOM_BACKEND}"
if [[ "${CLARITY_DICOM_BACKEND}" == "dcm2niix" ]]; then
  echo "  dcm2niix=${CLARITY_DCM2NIIX}"
fi
echo "  poll_seconds=${CLARITY_S3_POLL_SECONDS}"
echo "  max_cases=${CLARITY_S3_MAX_CASES:-<none>}"
echo "  delete_after_success=${CLARITY_DELETE_INPUT_AFTER_SUCCESS}"
echo "  delete_after_failure=${CLARITY_DELETE_INPUT_AFTER_FAILURE}"
echo "  fail_on_empty_tumor=${CLARITY_FAIL_ON_EMPTY_TUMOR}"
echo "  once=${CLARITY_S3_ONCE}"
if [[ -n "${AWS_PROFILE:-}" ]]; then
  echo "  aws_profile=${AWS_PROFILE}"
fi
echo "  aws_shared_credentials_file=${AWS_SHARED_CREDENTIALS_FILE}"
echo "  aws_config_file=${AWS_CONFIG_FILE}"
echo "  nnunet_raw=${nnUNet_raw:-<unset>}"
echo "  nnunet_preprocessed=${nnUNet_preprocessed:-<unset>}"
echo "  nnunet_results=${nnUNet_results:-<unset>}"

CMD=(
  "${WORKER_BIN}"
  --bucket "${CLARITY_S3_BUCKET}"
  --region "${AWS_DEFAULT_REGION}"
  --prefix-root "${CLARITY_S3_PREFIX_ROOT}"
  --work-root "${CLARITY_WORK_ROOT}"
  --weights-dir "${CLARITY_WEIGHTS_DIR}"
  --device "${CLARITY_DEVICE}"
  --dicom-backend "${CLARITY_DICOM_BACKEND}"
  --dcm2niix "${CLARITY_DCM2NIIX}"
  --poll-seconds "${CLARITY_S3_POLL_SECONDS}"
)

if [[ -n "${CLARITY_S3_MAX_CASES:-}" ]]; then
  CMD+=(--max-cases "${CLARITY_S3_MAX_CASES}")
fi

if [[ "${CLARITY_DELETE_INPUT_AFTER_SUCCESS}" == "1" ]]; then
  CMD+=(--delete-input-after-success)
fi
if [[ "${CLARITY_DELETE_INPUT_AFTER_FAILURE}" == "1" ]]; then
  CMD+=(--delete-input-after-failure)
fi
if [[ "${CLARITY_S3_ONCE}" == "1" ]]; then
  CMD+=(--once)
fi
if [[ "${CLARITY_FAIL_ON_EMPTY_TUMOR}" == "1" ]]; then
  CMD+=(--fail-on-empty-tumor)
fi

echo "Running: ${CMD[*]}"
exec "${CMD[@]}"
