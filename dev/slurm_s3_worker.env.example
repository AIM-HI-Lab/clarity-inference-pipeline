# Copy to dev/slurm_s3_worker.env and edit values.
# The Slurm job auto-loads this file if present.

# Optional in most cases (defaults are already set in the job):
# CLARITY_S3_BUCKET=clarity-upload-portal-prod
# CLARITY_WEIGHTS_DIR=/absolute/path/to/pnvrn_folds

# Recommended
AWS_PROFILE=clarity-worker
AWS_DEFAULT_REGION=us-east-1

# Worker behavior
CLARITY_S3_PREFIX_ROOT=clarity/submissions
CLARITY_WORK_ROOT=/scratch/$USER/clarity-s3-worker
CLARITY_DEVICE=cuda
CLARITY_S3_POLL_SECONDS=30
CLARITY_S3_MAX_CASES=
CLARITY_DELETE_INPUT_AFTER_SUCCESS=0
CLARITY_DELETE_INPUT_AFTER_FAILURE=0
CLARITY_S3_ONCE=0
